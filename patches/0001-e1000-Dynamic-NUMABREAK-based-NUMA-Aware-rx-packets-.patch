+++ b/drivers/net/ethernet/intel/e1000/e1000_main.c
@@ -7,6 +7,46 @@
 #include <linux/prefetch.h>
 #include <linux/bitops.h>
 #include <linux/if_vlan.h>
+#include <linux/percpu.h>
+
+// MY_MODS_START
+#include <linux/topology.h>
+#include <net/rx_timing.h>
+
+DEFINE_PER_CPU(bool, in_clean_alloc);
+DEFINE_PER_CPU(bool, in_rx_alloc);
+
+EXPORT_PER_CPU_SYMBOL(in_rx_alloc);
+EXPORT_PER_CPU_SYMBOL(in_clean_alloc);
+
+enum numabreak_vals {
+        numa_default = 0,
+        numa_low_pressure = 300,
+        numa_mid_low_pressure = 600,
+        numa_mid_high_pressure = 1532,
+        numa_high_pressure = 2048,
+};
+
+enum numabreak_ratios {
+        ratio_default = 100,
+        ratio_low = 35,
+        ratio_mid_low = 26,
+        ratio_mid_high = 18,
+        ratio_high = 10,
+};
+
+#define SLOW_NID 1
+#define FAST_NID 0
+ 
+unsigned int numabreak = numa_default;
+EXPORT_SYMBOL(numabreak);
+unsigned int dma_nid = 0;
+EXPORT_SYMBOL(dma_nid);
+
+void update_numabreak(void);
+static unsigned int current_node_mem_percent(void);
+void update_dma_nid(struct e1000_adapter* adapter, int packets, int bytes);
+// MY_MODS_END
 
 char e1000_driver_name[] = "e1000";
 static char e1000_driver_string[] = "Intel(R) PRO/1000 Network Driver";
@@ -225,6 +265,7 @@ static int __init e1000_init_module(void)
 	pr_info("%s\n", e1000_copyright);
 
 	ret = pci_register_driver(&e1000_driver);
+
 	if (copybreak != COPYBREAK_DEFAULT) {
 		if (copybreak == 0)
 			pr_info("copybreak disabled\n");
@@ -232,6 +273,8 @@ static int __init e1000_init_module(void)
 			pr_info("copybreak enabled for "
 				   "packets <= %u bytes\n", copybreak);
 	}
+
+	pr_info("My changes done\n");
 	return ret;
 }
 
@@ -2066,15 +2109,28 @@ static unsigned int e1000_frag_len(const struct e1000_adapter *a)
 		SKB_DATA_ALIGN(sizeof(struct skb_shared_info));
 }
 
+// MY_MODS_START
 static void *e1000_alloc_frag(const struct e1000_adapter *a)
 {
 	unsigned int len = e1000_frag_len(a);
-	u8 *data = netdev_alloc_frag(len);
+	u64 t0, dt;
+	u8 *data;
+
+	t0 = rx_ts();
+	data = netdev_alloc_frag(len);
+	if (t0) {
+		dt = ktime_get_ns() - t0;
+		this_cpu_add(rx_timing_data.frag_alloc_ns, dt);
+		this_cpu_inc(rx_timing_data.frag_alloc_cnt);
+		if (dt > __this_cpu_read(rx_timing_data.frag_alloc_max))
+			__this_cpu_write(rx_timing_data.frag_alloc_max, dt);
+	}
 
 	if (likely(data))
 		data += E1000_HEADROOM;
 	return data;
 }
+// MY_MODS_END
 
 /**
  * e1000_clean_rx_ring - Free Rx Buffers per Queue
@@ -3787,6 +3843,48 @@ static irqreturn_t e1000_intr(int irq, void *data)
 	return IRQ_HANDLED;
 }
 
+// MY_MODS_START
+
+void update_dma_nid(struct e1000_adapter* adapter, int packets, int bytes){
+
+    int avg;
+	if(!packets) return;
+	
+	avg = bytes/packets;
+	if(avg <= numabreak) dma_nid = SLOW_NID;
+	else dma_nid = FAST_NID;
+	return;
+}
+
+void update_numabreak(void)
+{
+	unsigned int cur_ratio = current_node_mem_percent();
+	if(cur_ratio <= ratio_high){
+		numabreak = numa_high_pressure;
+		goto ret;
+	}
+	if(cur_ratio <= ratio_mid_high){
+		numabreak = numa_mid_high_pressure;
+		goto ret;
+	}
+	if(cur_ratio <= ratio_mid_low){
+		numabreak = numa_mid_low_pressure;
+		goto ret;
+	}
+	if(cur_ratio <= ratio_low){
+		numabreak = numa_low_pressure;
+		goto ret;
+	}
+	if(cur_ratio <= ratio_default){
+		numabreak = numa_default;
+		goto ret;
+	}
+
+ret:
+	return;
+}
+// MY_MODS_END
+
 /**
  * e1000_clean - NAPI Rx polling callback
  * @napi: napi struct containing references to driver info
@@ -3800,7 +3898,7 @@ static int e1000_clean(struct napi_struct *napi, int budget)
 
 	tx_clean_complete = e1000_clean_tx_irq(adapter, &adapter->tx_ring[0]);
 
-	adapter->clean_rx(adapter, &adapter->rx_ring[0], &work_done, budget);
+	adapter->clean_rx(adapter, &adapter->rx_ring[0], &work_done, budget);	
 
 	if (!tx_clean_complete || work_done == budget)
 		return budget;
@@ -3815,6 +3913,13 @@ static int e1000_clean(struct napi_struct *napi, int budget)
 			e1000_irq_enable(adapter);
 	}
 
+	// MY_MODS_START
+	
+    update_numabreak();
+	update_dma_nid(adapter,adapter->total_rx_packets, adapter->total_rx_bytes);
+
+	// MY_MODS_END
+
 	return work_done;
 }
 
@@ -3998,6 +4103,11 @@ static void e1000_consume_page(struct e1000_rx_buffer *bi, struct sk_buff *skb,
 static void e1000_receive_skb(struct e1000_adapter *adapter, u8 status,
 			      __le16 vlan, struct sk_buff *skb)
 {
+	// MY_MODS_START
+	if (rx_timing_on)
+		skb->tstamp = ktime_get_ns();
+	// MY_MODS_END
+
 	skb->protocol = eth_type_trans(skb, adapter->netdev);
 
 	if (status & E1000_RXD_STAT_VP) {
@@ -4319,16 +4429,26 @@ static bool e1000_clean_jumbo_rx_irq(struct e1000_adapter *adapter,
 /* this should improve performance for small packets with large amounts
  * of reassembly being done in the stack
  */
+// MY_MODS_START
 static struct sk_buff *e1000_copybreak(struct e1000_adapter *adapter,
 				       struct e1000_rx_buffer *buffer_info,
 				       u32 length, const void *data)
 {
 	struct sk_buff *skb;
+	u64 t0, dt;
 
 	if (length > copybreak)
 		return NULL;
 
+	t0 = rx_ts();
 	skb = e1000_alloc_rx_skb(adapter, length);
+	if (t0) {
+		dt = ktime_get_ns() - t0;
+		this_cpu_add(rx_timing_data.copybreak_ns, dt);
+		this_cpu_inc(rx_timing_data.copybreak_cnt);
+		if (dt > __this_cpu_read(rx_timing_data.copybreak_max))
+			__this_cpu_write(rx_timing_data.copybreak_max, dt);
+	}
 	if (!skb)
 		return NULL;
 
@@ -4339,6 +4459,76 @@ static struct sk_buff *e1000_copybreak(struct e1000_adapter *adapter,
 
 	return skb;
 }
+// MY_MODS_END
+
+/*
+static struct sk_buff *e1000_copybreak(struct e1000_adapter *adapter,
+				       struct e1000_rx_buffer *buffer_info,
+				       u32 length, const void *data)
+{
+	struct sk_buff *skb;
+
+	if (length > copybreak)
+		return NULL;
+
+	skb = e1000_alloc_rx_skb(adapter, length);
+	if (!skb)
+		return NULL;
+
+	dma_sync_single_for_cpu(&adapter->pdev->dev, buffer_info->dma,
+				length, DMA_FROM_DEVICE);
+
+	skb_put_data(skb, data, length);
+
+	return skb;
+}
+*/
+
+// MY_MODS_START
+//void (*network_hook)(struct e1000_adapter *adapter, struct sk_buff *skb, u32 length) = NULL;
+//EXPORT_SYMBOL(network_hook);
+
+// Return the percentage of free RAM on current NUMA node
+static unsigned int current_node_mem_percent(void)
+{
+    int nid, z;
+    struct pglist_data *pgdat;
+    unsigned long total_pages;
+    unsigned long free_pages = 0;
+    unsigned int percentage;
+
+    nid = numa_node_id();
+    pgdat = NODE_DATA(nid);
+
+    if (unlikely(!pgdat))
+        return 0;
+
+    total_pages = pgdat->node_present_pages;
+
+    if (unlikely(total_pages == 0))
+        return 0;
+
+    for (z = 0; z < MAX_NR_ZONES; z++) {
+        struct zone *zone = &pgdat->node_zones[z];
+        
+        if (populated_zone(zone)) {
+            long pages = atomic_long_read(&zone->vm_stat[NR_FREE_PAGES]);
+            if (pages > 0) {
+                free_pages += pages;
+            }
+        }
+    }
+
+    if (unlikely(free_pages > total_pages))
+        free_pages = total_pages;
+
+    percentage = (unsigned int)((free_pages * 100) / total_pages);
+
+    return percentage;
+}
+
+
+// MY_MODS_END
 
 /**
  * e1000_clean_rx_irq - Send received data up the network stack; legacy
@@ -4361,6 +4551,10 @@ static bool e1000_clean_rx_irq(struct e1000_adapter *adapter,
 	bool cleaned = false;
 	unsigned int total_rx_bytes = 0, total_rx_packets = 0;
 
+	// MY MODS START 
+	this_cpu_write(in_clean_alloc, true);
+	// MY MODS END
+
 	i = rx_ring->next_to_clean;
 	rx_desc = E1000_RX_DESC(*rx_ring, i);
 	buffer_info = &rx_ring->buffer_info[i];
@@ -4370,6 +4564,12 @@ static bool e1000_clean_rx_irq(struct e1000_adapter *adapter,
 		u8 *data;
 		u8 status;
 
+		// MY_MODS_START
+		
+		u64 t0, t_pfetch, dt;
+		
+		// MY_MODS_END
+
 		if (*work_done >= work_to_do)
 			break;
 		(*work_done)++;
@@ -4379,12 +4579,39 @@ static bool e1000_clean_rx_irq(struct e1000_adapter *adapter,
 		length = le16_to_cpu(rx_desc->length);
 
 		data = buffer_info->rxbuf.data;
+	
+		// MY_MODS_START	
+
+		t_pfetch = rx_ts();
 		prefetch(data);
+		if (t_pfetch) {
+			dt = ktime_get_ns() - t_pfetch;
+			this_cpu_add(rx_timing_data.prefetch_gap_ns, dt);
+			this_cpu_inc(rx_timing_data.prefetch_gap_cnt);
+		}
+
+		// MY_MODS_END
+
 		skb = e1000_copybreak(adapter, buffer_info, length, data);
 		if (!skb) {
 			unsigned int frag_len = e1000_frag_len(adapter);
 
+			// MY_MODS_START
+			
+
+			t0 = rx_ts();
 			skb = napi_build_skb(data - E1000_HEADROOM, frag_len);
+			if (t0 && skb) {
+				dt = ktime_get_ns() - t0;
+				this_cpu_add(rx_timing_data.build_skb_ns, dt);
+				this_cpu_inc(rx_timing_data.build_skb_cnt);
+				if (dt > __this_cpu_read(rx_timing_data.build_skb_max))
+					__this_cpu_write(rx_timing_data.build_skb_max, dt);
+			}
+
+			// MY_MODS_END
+			
+
 			if (!skb) {
 				adapter->alloc_rx_buff_failed++;
 				break;
@@ -4397,7 +4624,7 @@ static bool e1000_clean_rx_irq(struct e1000_adapter *adapter,
 			buffer_info->dma = 0;
 			buffer_info->rxbuf.data = NULL;
 		}
-
+		
 		if (++i == rx_ring->count)
 			i = 0;
 
@@ -4417,7 +4644,7 @@ static bool e1000_clean_rx_irq(struct e1000_adapter *adapter,
 		 */
 		if (unlikely(!(status & E1000_RXD_STAT_EOP)))
 			adapter->discarding = true;
-
+	
 		if (adapter->discarding) {
 			/* All receives must fit into a single buffer */
 			netdev_dbg(netdev, "Receive packet consumed multiple buffers\n");
@@ -4486,6 +4713,11 @@ static bool e1000_clean_rx_irq(struct e1000_adapter *adapter,
 	adapter->total_rx_bytes += total_rx_bytes;
 	netdev->stats.rx_bytes += total_rx_bytes;
 	netdev->stats.rx_packets += total_rx_packets;
+
+	// MY MODS START 
+	this_cpu_write(in_clean_alloc, false); 
+	// MY MODS END
+
 	return cleaned;
 }
 
@@ -4570,6 +4802,10 @@ static void e1000_alloc_rx_buffers(struct e1000_adapter *adapter,
 	struct e1000_rx_buffer *buffer_info;
 	unsigned int i;
 	unsigned int bufsz = adapter->rx_buffer_len;
+	
+	// MY MODS START 
+	this_cpu_write(in_rx_alloc, true);
+	// MY MODS END
 
 	i = rx_ring->next_to_use;
 	buffer_info = &rx_ring->buffer_info[i];
@@ -4669,6 +4905,9 @@ static void e1000_alloc_rx_buffers(struct e1000_adapter *adapter,
 		dma_wmb();
 		writel(i, hw->hw_addr + rx_ring->rdt);
 	}
+	// MY MODS START 
+	this_cpu_write(in_rx_alloc, false); 
+	// MY MODS END
 }
 
